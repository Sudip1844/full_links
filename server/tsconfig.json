{
  "include": ["*.ts", "shared/**/*"],
  "exclude": ["node_modules", "build", "dist", "**/*.test.ts"],
  "compilerOptions": {
    "incremental": true,
    "tsBuildInfoFile": "./node_modules/typescript/tsbuildinfo",
    "outDir": "./dist",
    "noEmit": false,
    "target": "ES2022",
    "module": "ESNext",
    "strict": false,
    "noImplicitAny": false,
    "noImplicitReturns": false,
    "lib": ["ES2022"],
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "moduleResolution": "node",
    "baseUrl": ".",
    "types": ["node"],
    "paths": {
      "@shared/*": ["./shared/*"]
    },
    "declaration": false,
    "sourceMap": false,
    "removeComments": true
  }
}