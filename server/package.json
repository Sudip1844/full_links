{
  "name": "moviezone-server",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "NODE_ENV=development tsx index.ts",
    "build": "rm -rf dist && mkdir -p dist && cp *.ts *.js package.json .env.example dist/ && cp -r shared dist/ 2>/dev/null || true",
    "start": "NODE_ENV=production tsx index.ts",
    "check": "tsc",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "drizzle-orm": "^0.39.1",
    "drizzle-zod": "^0.7.0",
    "express": "^4.21.2",
    "express-session": "^1.18.1",
    "memorystore": "^1.6.7",
    "node-fetch": "^3.3.2",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0",
    "postgres": "^3.4.7",
    "ws": "^8.18.0",
    "zod": "^3.24.2",
    "zod-validation-error": "^3.4.0",
    "crypto": "^1.0.1",
    "typescript": "5.6.3",
    "@types/cors": "^2.8.17",
    "@types/express": "4.17.21",
    "@types/express-session": "^1.18.0",
    "@types/node": "20.16.11",
    "@types/passport": "^1.0.16",
    "@types/passport-local": "^1.0.38",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.1"
  },
  "devDependencies": {
    "drizzle-kit": "^0.30.4",
    "esbuild": "^0.25.0"
  },
  "optionalDependencies": {
    "bufferutil": "^4.0.8"
